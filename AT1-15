START
// Primitive Data Types
DECLARE Temperature AS Float
DECLARE Humidity AS Float
DECLARE WindSpeed AS Float
// Non-Primitive Data Structure
CREATE Structure WeatherRecord
    Temperature
    Humidity
    WindSpeed
END Structure
// Linear Data Structure
CREATE Array WeatherData[100]
FOR i = 0 TO 99
    READ Temperature
    READ Humidity
    READ WindSpeed
    STORE values in WeatherData[i]
END FOR
// Non-Linear Data Structure
CREATE Tree WeatherStations
CREATE Graph SensorNetwork
// Organize Weather Stations
ADD Stations to Tree
CONNECT Sensors using Graph
// Display Weather Records
FOR each Record in WeatherData
    DISPLAY Temperature, Humidity, WindSpeed
END FOR
// Applications
DISPLAY "Weather Forecasting"
DISPLAY "Climate Monitoring"
DISPLAY "Disaster Warning"
STOP
